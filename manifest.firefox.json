{
  "manifest_version": 3,
  "name": "Reply Better AI",
  "version": "1.2.1",
  "description": "Improve your messages using AI. Pick from 500+ OpenRouter models with search, pricing, and free filter.",
  "browser_specific_settings": {
    "gecko": {
      "id": "hi@antnan.com",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": [
          "authenticationInfo",
          "personalCommunications"
        ]
      }
    }
  },
  "icons": {
    "512": "icons/icon.png"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://openrouter.ai/*"
  ],
  "action": {
    "default_icon": "icons/icon.png",
    "default_title": "Reply Better AI",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": [
      "service-worker.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}
